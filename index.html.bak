<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Portfolio of Zhansaya Kyrgyzmolda, a junior AI researcher and engineer studying Artificial Intelligence at Pusan National University.">
  <meta name="theme-color" content="#050914">
  <meta property="og:title" content="Zhansaya Kyrgyzmolda | Junior AI Researcher & Engineer">
  <meta property="og:description" content="AI portfolio covering NLP, computer vision, robotics, embedded systems, and AI applications.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://jans-saya.github.io/">
  <link rel="icon" href="assets/images/ui/logo.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="assets/css/site.css">
  <title>Zhansaya Kyrgyzmolda | Junior AI Researcher & Engineer</title>

  <style>
    .home-hero-v2 {
      min-height: 100vh;
      padding: 150px 0 88px;
    }

    .home-hero-v2 .hero-grid {
      grid-template-columns: minmax(0, 1.12fr) minmax(360px, .88fr);
      gap: clamp(30px, 4vw, 58px);
      align-items: center;
    }

    .home-hero-v2 .hero-copy {
      max-width: 760px;
    }

    .home-hero-v2 .hero-name {
      margin: 0 0 18px;
      color: var(--cyan);
      font-size: .74rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
    }

    .home-hero-v2 h1 {
      max-width: 760px;
      margin: 0;
      font: 600 clamp(2.35rem, 3.6vw, 3.5rem)/1.06 "Space Grotesk";
      letter-spacing: -.04em;
    }

    .home-hero-v2 h1 span {
      display: block;
      white-space: nowrap;
    }

    .home-hero-v2 .lede {
      max-width: 680px;
      margin-top: 26px;
      font-size: clamp(1rem, 1.4vw, 1.12rem);
    }

    .home-hero-v2 .availability {
      margin-top: 24px;
    }

    .hero-robot {
      position: relative;
      min-height: 430px;
      display: grid;
      place-items: center;
      isolation: isolate;
    }

    .hero-robot::before {
      content: "";
      position: absolute;
      inset: 10% 8%;
      border-radius: 32px;
      background:
        radial-gradient(circle at 30% 30%, rgba(104,231,255,.14), transparent 30%),
        radial-gradient(circle at 75% 20%, rgba(156,125,255,.16), transparent 32%),
        linear-gradient(180deg, rgba(10,17,28,.55), rgba(10,17,28,.15));
      filter: blur(0.5px);
      z-index: -2;
    }

    .hero-robot::after {
      content: "";
      position: absolute;
      width: min(540px, 96%);
      height: min(420px, 92%);
      border-radius: 32px;
      border: 1px solid rgba(137,193,235,.14);
      box-shadow:
        0 20px 70px rgba(0, 0, 0, .34),
        0 0 0 1px rgba(255,255,255,.02) inset;
      z-index: -1;
    }

    .hero-visual-panel {
      width: min(560px, 100%);
      padding: 10px;
      border-radius: 24px;
      background: rgba(7,12,22,.42);
      border: 1px solid rgba(137,193,235,.14);
      box-shadow: 0 24px 60px rgba(0,0,0,.32);
      backdrop-filter: blur(8px);
    }

    .hero-visual-panel img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 16px;
      object-fit: cover;
      box-shadow: 0 14px 36px rgba(0,0,0,.28);
    }


    /* Keep the expertise cards readable at different widths. */
    .domain-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .domain-card {
      min-width: 0;
    }

    .domain-card h3 {
      margin: 28px 0 12px;
      font-family: Inter, system-ui, sans-serif;
      font-size: clamp(1.2rem, 1.8vw, 1.55rem);
      font-weight: 600;
      line-height: 1.18;
      letter-spacing: -.025em;
      overflow-wrap: anywhere;
    }

    .domain-card p {
      overflow-wrap: anywhere;
    }

    @media (max-width: 760px) {
      .domain-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 980px) {
      .home-hero-v2 {
        padding-top: 130px;
      }

      .home-hero-v2 .hero-grid {
        grid-template-columns: 1fr;
      }

      .hero-robot {
        min-height: 380px;
      }

      .hero-visual-panel {
        width: min(560px, 92vw);
        padding: 14px;
      }
    }

    @media (max-width: 620px) {
      .home-hero-v2 h1 span {
        white-space: normal;
      }
    }
  </style>
</head>

<body class="home-page">
  <canvas id="network" aria-hidden="true"></canvas>
  <div class="noise" aria-hidden="true"></div>

  <div class="boot" aria-hidden="true">
    <div class="boot-card">
